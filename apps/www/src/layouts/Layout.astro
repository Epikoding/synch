---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "Synch - Open-source E2EE sync for Obsidian" } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-[#0a0a0a] text-zinc-400 font-sans antialiased selection:bg-zinc-800 selection:text-zinc-200 min-h-screen flex flex-col font-light text-sm">
		<slot />
	</body>
</html>
