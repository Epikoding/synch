---
import '../styles/global.css';
import { getLocale, ui, type Locale } from '../i18n';

interface Props {
	title?: string;
	locale?: Locale;
}

const locale = Astro.props.locale ?? getLocale(Astro.currentLocale);
const { title = ui[locale].meta.defaultTitle } = Astro.props;
---
<!doctype html>
<html lang={locale} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-[#0a0a0a] text-zinc-400 font-sans antialiased selection:bg-zinc-800 selection:text-zinc-200 min-h-screen flex flex-col text-sm">
		<slot />
	</body>
</html>
