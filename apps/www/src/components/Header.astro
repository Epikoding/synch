---
import { getLocale, localizedPath, ui, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? getLocale(Astro.currentLocale);
const t = ui[locale].nav;
const apiUrl = import.meta.env.PUBLIC_API_URL || "";
const vaultsUrl = new URL("/vaults", apiUrl || Astro.url.origin).toString();
const authButtonClass =
  "inline-flex h-8 min-w-16 items-center justify-center rounded bg-zinc-200 px-3 text-xs font-medium text-[#0a0a0a] transition-colors hover:bg-white";
---

<header class="py-12 flex items-center justify-between">
  <a
    href={localizedPath(locale)}
    class="text-zinc-200 font-normal tracking-wider text-xs uppercase hover:opacity-80 transition-opacity"
    >Synch</a
  >
  <nav class="flex items-center gap-6 text-xs">
    <a href={localizedPath(locale, "/pricing")} class="hover:text-zinc-200 transition-colors">{t.pricing}</a>
    <a
      href="https://github.com/hjinco/synch"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-zinc-200 transition-colors">{t.github}</a
    >
    <div class="w-px h-3 bg-zinc-800"></div>
    <button
      id="auth-link"
      type="button"
      data-waitlist-open
      class={authButtonClass}>{t.joinWaitlist}</button
    >
  </nav>
</header>

<script
  define:vars={{ apiUrl, authButtonClass, vaultsLabel: t.vaults, vaultsUrl }}
>
  async function checkAuth() {
    const authLink = document.getElementById("auth-link");
    if (!authLink) return;

    try {
      const response = await fetch(`${apiUrl}/api/auth/get-session`, {
        credentials: "include",
        headers: { accept: "application/json" },
      });
      const session = response.ok ? await response.json() : null;

      if (session?.user) {
        authLink.textContent = vaultsLabel;
        authLink.removeAttribute("data-waitlist-open");
        authLink.addEventListener("click", () => {
          window.location.href = vaultsUrl;
        });
        authLink.className = authButtonClass;
      }
    } catch (error) {
      authLink.className = authButtonClass;
    }
  }

  checkAuth();
</script>
