---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const apiUrl = import.meta.env.PUBLIC_API_URL || "";
const vaultsUrl = new URL("/vaults", apiUrl || Astro.url.origin).toString();
const signUpUrl = new URL("/signup", apiUrl || Astro.url.origin);
signUpUrl.searchParams.set("return_to", vaultsUrl);
---

<Layout>
  <div class="max-w-2xl mx-auto px-6 w-full flex-1 flex flex-col">
    <Header />

    <!-- Main Content -->
    <main class="flex-1 flex flex-col justify-center py-24">
      <div class="space-y-6">
        <h1
          class="text-2xl sm:text-3xl font-light text-zinc-200 tracking-tight"
        >
          End-to-end encrypted sync<br />for Obsidian.
        </h1>

        <p class="max-w-md leading-relaxed text-zinc-500">
          An open-source alternative to Obsidian Sync. Your notes are encrypted
          locally before leaving your device, ensuring complete privacy and
          control over your data.
        </p>

        <div class="flex items-center gap-4 pt-4 text-xs">
          <a
            href={signUpUrl.toString()}
            class="px-4 py-2 bg-zinc-800 text-zinc-200 hover:bg-zinc-700 rounded transition-colors"
          >
            Get Started
          </a>
          <a
            href="https://github.com/hjinco/synch"
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 bg-transparent text-zinc-400 border border-zinc-800 hover:border-zinc-700 hover:text-zinc-300 rounded transition-all"
          >
            View Source
          </a>
        </div>
      </div>

      <!-- Features -->
      <div class="grid sm:grid-cols-2 gap-12 mt-32">
        <div class="space-y-3">
          <div class="w-8 h-px bg-zinc-800"></div>
          <h3 class="text-zinc-300 font-normal">Zero Knowledge</h3>
          <p class="text-zinc-500 leading-relaxed">
            Everything is encrypted with AES-256-GCM on your device. The server
            never sees your raw notes.
          </p>
        </div>
        <div class="space-y-3">
          <div class="w-8 h-px bg-zinc-800"></div>
          <h3 class="text-zinc-300 font-normal">Open Source</h3>
          <p class="text-zinc-500 leading-relaxed">
            Built in the open. You can inspect the code, host it yourself, or
            contribute to the project on GitHub.
          </p>
        </div>
      </div>

      <!-- Installation -->
      <div class="mt-32 space-y-6">
        <div class="w-8 h-px bg-zinc-800"></div>
        <h2 class="text-xl text-zinc-300 font-normal">How to Install</h2>
        <div class="space-y-6 text-zinc-500 leading-relaxed">
          <p>
            The Synch plugin is currently in early development and can be installed via the 
            <a href="https://github.com/TfTHacker/obsidian42-brat" target="_blank" rel="noopener noreferrer" class="text-zinc-300 hover:text-zinc-200 underline decoration-zinc-700 hover:decoration-zinc-500 transition-colors underline-offset-4">BRAT</a> 
            plugin.
          </p>
          
          <ol class="space-y-3 list-decimal list-inside marker:text-zinc-700">
            <li>Open Obsidian Settings and go to <span class="text-zinc-300">Community plugins</span>.</li>
            <li>Turn off Safe mode and click <span class="text-zinc-300">Browse</span>.</li>
            <li>Search for and install <span class="text-zinc-300">Obsidian42 - BRAT</span>, then enable it.</li>
            <li>Open the BRAT settings, and click <span class="text-zinc-300">Add Beta plugin</span>.</li>
            <li>
              Enter the repository URL: 
              <button 
                type="button" 
                class="group relative inline-flex items-center gap-1.5 px-2 py-0.5 bg-zinc-800/50 hover:bg-zinc-800 transition-colors rounded text-sm text-zinc-400 hover:text-zinc-300 font-mono"
                onclick="navigator.clipboard.writeText('https://github.com/hjinco/synch'); const copy = this.querySelector('.copy-icon'); const check = this.querySelector('.check-icon'); copy.classList.add('hidden'); check.classList.remove('hidden'); setTimeout(() => { copy.classList.remove('hidden'); check.classList.add('hidden'); }, 2000);"
                title="Copy to clipboard"
              >
                <span>https://github.com/hjinco/synch</span>
                <span class="text-zinc-500 group-hover:text-zinc-400">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon hidden text-emerald-500"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
              </button> 
              and add it.
            </li>
            <li>Go back to Community plugins and enable <span class="text-zinc-300">Synch</span>.</li>
          </ol>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <Footer />
  </div>
</Layout>
